{
  "version": "1.0.0",
  "runtime": {
    "type": "flask",
    "port": 8086,
    "auth": true
  },
  "modules": {
    "memory": { "enabled": true, "engine": "vector" },
    "agents": { "enabled": true, "max_concurrent": 5 },
    "cluster": { "enabled": false },
    "consensus": { "enabled": false },
    "scheduler": { "enabled": true },
    "knowledge": { "enabled": true },
    "events": { "enabled": true }
  },
  "providers": {
    "default": "ollama",
    "ollama": { "endpoint": "http://localhost:11434" }
  },
  "nodes": [
    {"id": "memory.index", "model": "qwen2.5-coder", "watch": "artifacts/raw_memory", "emit": "artifacts/vector_memory"},
    {"id": "knowledge.sync", "depends": ["memory.index"]}
  ]
}
